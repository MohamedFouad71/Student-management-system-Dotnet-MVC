@using StudentManagementSystem.Views.ViewModels
@model StudentViewModel

<div class="glass-container fade-in-up" style="animation-delay: 0.2s; max-width: 600px; margin: 0 auto;">
    <h2 class="text-center mb-4 text-white">Modify Student</h2>

    <form asp-action="Modify" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name" class="form-label">Student Name</label>
            <input asp-for="Name" class="glass-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
            <input asp-for="DateOfBirth" class="glass-input" type="date" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" class="glass-input" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentId" class="form-label">Department</label>
            <select asp-for="DepartmentId" asp-items="Model.Departments" class="glass-input">
                <option value="">-- Select Department --</option>
            </select>
            <span asp-validation-for="DepartmentId" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <a asp-action="Index" class="btn-glass-outline">Cancel</a>
            <button type="submit" class="btn-glass">Save Changes</button>
        </div>
    </form>
</div>