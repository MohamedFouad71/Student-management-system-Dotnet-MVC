@model List<Student>

<div class="glass-container fade-in-up" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Students</h2>
        <a asp-controller="Student" asp-action="Create" class="btn-glass">
            <i class="bi bi-plus-lg me-1"></i> New Student
        </a>
    </div>

    <div class="table-responsive">
        <table class="table glass-table">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Name</th>
                    <th scope="col">Email Address</th>
                    <th scope="col">Date of Birth</th>
                    <th scope="col">Department</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td><span class="text-white-50">#@student.Id</span></td>
                        <td class="font-weight-bold">@student.Name</td>
                        <td>@student.Email</td>
                        <td>@student.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (student.Department != null)
                            {
                                <span class="badge bg-secondary bg-opacity-50 text-white">@student.Department.Name</span>
                            }
                            else
                            {
                                <span class="text-white-50 fst-italic">None</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-controller="Attendance" asp-action="StudentAttendance" asp-route-id="@student.Id" class="btn btn-sm btn-outline-info" title="Attendance">
                                    <i class="bi bi-calendar-check"></i> Attendance
                                </a>
                                <a asp-controller="Enrollment" asp-action="Index" asp-route-studentId="@student.Id" class="btn btn-sm btn-outline-success mx-1" title="Enrollments">
                                    <i class="bi bi-journal-bookmark-fill"></i> Enrollments
                                </a>
                                <a asp-action="Modify" asp-route-id="@student.Id" class="btn btn-sm btn-outline-warning mx-1" title="Modify">
                                    <i class="bi bi-pencil-square"></i> Modify
                                </a>
                                <form asp-action="StudentDelete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@student.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this Student?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
