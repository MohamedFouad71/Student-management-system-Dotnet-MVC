@model List<Enrollment>

<div class="glass-container fade-in-up" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Student Enrollments</h2>
        <a asp-action="Create" asp-route-studentId="@ViewBag.studentId" class="btn-glass">
            <i class="bi bi-plus-lg me-1"></i> Add Grade
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table glass-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var enrollment in Model)
                    {
                        <tr>
                            <td class="font-weight-bold">@enrollment.Course?.Name</td>
                            <td>
                                @if (enrollment.Grade.HasValue)
                                {
                                    <span class="badge bg-primary bg-opacity-75 text-white shadow-sm" style="font-weight: 500; padding: 0.5em 0.8em;">@enrollment.Grade.ToString()</span>
                                }
                                else
                                {
                                    <span class="text-white-50 fst-italic">Not Graded</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert text-center" style="background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,255,255,0.2); color: var(--text-secondary);">
            <p class="mb-0 py-3">No enrollments found.</p>
        </div>
    }
</div>

