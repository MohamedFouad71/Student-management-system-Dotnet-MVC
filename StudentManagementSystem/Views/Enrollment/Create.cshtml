@using StudentManagementSystem.Views.ViewModels

@model EnrollmentViewModel

<div class="glass-container fade-in-up" style="animation-delay: 0.2s; max-width: 600px; margin: 0 auto;">
    <h2 class="text-center mb-4 text-white">Add Enrollment / Grade</h2>

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="StudentId" />
        
        <div class="form-group">
            <label asp-for="CourseId" class="form-label">Course</label>
            <select asp-for="CourseId" asp-items="Model.Courses" class="glass-input">
                <option value="">-- Select Course --</option>
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Grade" class="form-label">Grade</label>
            <input asp-for="Grade" class="glass-input" placeholder="Enter grade (optional)" />
            <span asp-validation-for="Grade" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <button type="button" onclick="history.back()" class="btn-glass-outline">Cancel</button>
            <button type="submit" class="btn-glass">Save Enrollment</button>
        </div>
    </form>
</div>