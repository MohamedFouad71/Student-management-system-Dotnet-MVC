@using StudentManagementSystem.Views.ViewModels

@model EnrollmentViewModel

<link href="./css/views.css" rel="stylesheet" />

<form asp-action="Create" method="post">

    <input type="hidden" asp-for="StudentId" />
    
    <div class="form-group">
        <label asp-for="CourseId" class="control-label"></label>
        <select asp-for="CourseId" asp-items="Model.Courses" class="form-control">
            <option value="">-- Select Course --</option>
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Grade" class="control-label"></label>
        <input asp-for="Grade" class="form-control" />
        <span asp-validation-for="Grade" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Add</button>
</form>