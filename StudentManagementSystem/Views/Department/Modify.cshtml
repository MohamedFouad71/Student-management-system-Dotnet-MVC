@model Department

<div class="glass-container fade-in-up" style="animation-delay: 0.2s; max-width: 600px; margin: 0 auto;">
    <h2 class="text-center mb-4 text-white">Modify Department</h2>

    <form asp-action="Modify" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name" class="form-label">Department Name</label>
            <input asp-for="Name" class="glass-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <a asp-action="Index" class="btn-glass-outline">Cancel</a>
            <button type="submit" class="btn-glass">Save Changes</button>
        </div>
    </form>
</div>