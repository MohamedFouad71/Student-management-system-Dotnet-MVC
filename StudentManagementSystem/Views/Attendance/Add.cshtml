@model AttendanceViewModel

<div class="glass-container fade-in-up" style="animation-delay: 0.2s; max-width: 600px; margin: 0 auto;">
    <h2 class="text-center mb-4 text-white">Add Attendance</h2>

    <form asp-action="Add" method="post">
        <input type="hidden" asp-for="StudentId" />

        <div class="form-group">
            <label asp-for="CourseId" class="form-label">Select Course</label>
            <select asp-for="CourseId" asp-items="Model.Courses" class="glass-input"></select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Date" class="form-label">Attendance Date</label>
            <input asp-for="Date" class="glass-input" type="date" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="form-check my-4">
            <input asp-for="IsPresent" class="form-check-input" style="transform: scale(1.3); margin-top: 0.3rem;" />
            <label asp-for="IsPresent" class="form-check-label ms-2 text-white" style="font-size: 1.1rem; cursor: pointer;">Student is Present</label>
        </div>

        <div class="text-center mt-5">
            <button type="submit" class="btn-glass w-100">Save Attendance</button>
        </div>
    </form>
</div>
