<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Student Management System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Layout.css"/>
</head>
<body>
    <nav class="navbar navbar-expand-lg glass-navbar mb-4 fade-in-up">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">System.</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Student" asp-action="Index">Students</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Department" asp-action="Index">Departments</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Instructor" asp-action="Index">Instructors</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Attendance" asp-action="Index">Attendance</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container fade-in-up" style="animation-delay: 0.1s;">
        @RenderBody()
    </div>

    <footer class="fade-in-up" style="animation-delay: 0.2s;">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - Premium Student Management System</small>
        </div>
    </footer>
</body>
</html>
