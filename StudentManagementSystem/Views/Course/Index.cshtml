@model List<Course>

<div class="glass-container fade-in-up" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Courses</h2>
        <a asp-action="Create" class="btn-glass">
            <i class="bi bi-plus-lg me-1"></i> New Course
        </a>
    </div>

    <div class="table-responsive">
        <table class="table glass-table">
            <thead>
                <tr>
                    <th scope="col">Course ID</th>
                    <th scope="col">Course Name</th>
                    <th scope="col">Credit Hours</th>
                    <th scope="col">Department</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td><span class="text-white-50">#@course.Id</span></td>
                        <td class="font-weight-bold">@course.Name</td>
                        <td>@course.Credits</td>
                        <td><span class="badge bg-secondary bg-opacity-50 text-white">@course.Department.Name</span></td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-controller="Attendance" asp-action="CourseAttendance" asp-route-id="@course.Id" class="btn btn-sm btn-outline-info" title="Attendance">
                                    <i class="bi bi-calendar-check"></i> Attendance
                                </a>
                                <a asp-action="Modify" asp-route-id="@course.Id" class="btn btn-sm btn-outline-warning mx-1" title="Modify">
                                    <i class="bi bi-pencil-square"></i> Modify
                                </a>
                                <form asp-action="CourseDelete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this course?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
