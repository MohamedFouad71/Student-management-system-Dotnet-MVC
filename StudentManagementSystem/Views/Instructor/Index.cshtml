@model List<Instructor>

<div class="glass-container fade-in-up" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Instructors</h2>
        <a asp-controller="Instructor" asp-action="Create" class="btn-glass">
            <i class="bi bi-plus-lg me-1"></i> New Instructor
        </a>
    </div>

    <div class="table-responsive">
        <table class="table glass-table">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Name</th>
                    <th scope="col">Hire Date</th>
                    <th scope="col">Office Location</th>
                    <th scope="col" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var instructor in Model)
                {
                    <tr>
                        <td><span class="text-white-50">#@instructor.Id</span></td>
                        <td class="font-weight-bold">@instructor.Name</td>
                        <td>@instructor.HireDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (instructor.OfficeAssignment?.Location != null)
                            {
                                <span class="badge bg-secondary bg-opacity-50 text-white">@instructor.OfficeAssignment.Location</span>
                            }
                            else
                            {
                                <span class="text-white-50 fst-italic">Not Specified</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Modify" asp-route-id="@instructor.Id" class="btn btn-sm btn-outline-warning mx-1" title="Modify">
                                    <i class="bi bi-pencil-square"></i> Modify
                                </a>
                                <form asp-action="InstructorDelete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@instructor.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this instructor?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>