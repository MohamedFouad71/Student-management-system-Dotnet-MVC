@using StudentManagementSystem.Views.ViewModels
@model InstructorViewModel

<div class="glass-container fade-in-up" style="animation-delay: 0.2s; max-width: 600px; margin: 0 auto;">
    <h2 class="text-center mb-4 text-white">Add Instructor</h2>

    <form asp-action="Create" method="post">

        <div class="form-group">
            <label asp-for="InstructorName" class="form-label">Instructor Name</label>
            <input asp-for="InstructorName" class="glass-input" placeholder="e.g. Dr. John Doe" />
            <span asp-validation-for="InstructorName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="InstructorHireDate" class="form-label">Hire Date</label>
            <input asp-for="InstructorHireDate" class="glass-input" type="date" />
            <span asp-validation-for="InstructorHireDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="OfficeLocation" class="form-label">Office Location</label>
            <input asp-for="OfficeLocation" class="glass-input" placeholder="e.g. Room 402, Building A" />
            <span asp-validation-for="OfficeLocation" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <a asp-action="Index" class="btn-glass-outline">Cancel</a>
            <button type="submit" class="btn-glass">Add Instructor</button>
        </div>
    </form>
</div>